   "source": [
    "# LLM Zoomcamp 2026 — Module 2 Homework: Vector Search\n",
    "\n",
    "GitHub repo: `sydniegsiyhian-git/llm-zoomcamp-2026`"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b2c3d4e5",
   "metadata": {},
   "source": [
    "## Setup\n",
    "\n",
    "Run in terminal before starting:\n",
    "```bash\n",
    "uv add onnxruntime tokenizers numpy tqdm minsearch gitsource\n",
    "uv add --dev huggingface-hub jupyter\n",
    "wget https://raw.githubusercontent.com/DataTalksClub/llm-zoomcamp/main/02-vector-search/embed/download.py\n",
    "wget https://raw.githubusercontent.com/DataTalksClub/llm-zoomcamp/main/02-vector-search/embed/embedder.py\n",
    "python download.py\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c3d4e5f6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "from embedder import Embedder\n",
    "\n",
    "embedder = Embedder(\"models/Xenova/all-MiniLM-L6-v2\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d4e5f6a7",
   "metadata": {},
   "source": [
    "## Q1. Embedding a query"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e5f6a7b8",
   "metadata": {},
   "outputs": [],
   "source": [
    "query_q1 = \"How does approximate nearest neighbor search work?\"\n",
    "v = embedder.encode(query_q1)\n",
    "\n",
    "print(f\"v[0] = {v[0]:.4f}\")\n",
    "print(f\"Rounded: {round(float(v[0]), 2)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f6a7b8c9",
   "metadata": {},
   "source": [
    "**Answer Q1: `-0.02`**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a7b8c9d0",
   "metadata": {},
   "source": [
    "## Load the data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b8c9d0e1",
   "metadata": {},
   "outputs": [],
   "source": [
    "from gitsource import GithubRepositoryDataReader\n",
    "\n",
    "reader = GithubRepositoryDataReader(\n",
    "    repo_owner=\"DataTalksClub\",\n",
    "    repo_name=\"llm-zoomcamp\",\n",
    "    commit_id=\"8c1834d\",\n",
    "    allowed_extensions={\"md\"},\n",
    "    filename_filter=lambda path: \"/lessons/\" in path,\n",
    ")\n",
    "\n",
    "documents = [file.parse() for file in reader.read()]\n",
    "print(f\"Loaded {len(documents)} documents\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c9d0e1f2",
   "metadata": {},
   "source": [
    "## Q2. Cosine similarity"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d0e1f2a3",
   "metadata": {},
   "outputs": [],
   "source": [
    "target_file = \"02-vector-search/lessons/07-sqlitesearch-vector.md\"\n",
    "target_doc = next(d for d in documents if d[\"filename\"] == target_file)\n",
    "\n",
    "v_doc = embedder.encode(target_doc[\"content\"])\n",
    "\n",
    "# Vectors are normalized, so dot product = cosine similarity\n",
    "cosine_sim = float(np.dot(v, v_doc))\n",
    "print(f\"Cosine similarity: {cosine_sim:.4f}\")\n",
    "print(f\"Rounded: {round(cosine_sim, 2)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e1f2a3b4",
   "metadata": {},
   "source": [
    "**Answer Q2: `0.68`**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f2a3b4c5",
   "metadata": {},
   "source": [
    "## Q3. Chunking and search by hand"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a3b4c5d6",
   "metadata": {},
   "outputs": [],
   "source": [
    "from gitsource import chunk_documents\n",
    "\n",
    "chunks = chunk_documents(documents, size=2000, step=1000)\n",
    "print(f\"Total chunks: {len(chunks)}\")\n",
    "\n",
    "# Embed all chunks\n",
    "contents = [c[\"content\"] for c in chunks]\n",
    "X = np.array(embedder.encode_batch(contents))\n",
    "print(f\"Matrix shape: {X.shape}\")\n",
    "\n",
    "# Score Q1 query against all chunks\n",
    "scores = X.dot(v)\n",
    "best_idx = int(np.argmax(scores))\n",
    "\n",
    "print(f\"Best chunk filename: {chunks[best_idx]['filename']}\")\n",
    "print(f\"Best score: {scores[best_idx]:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b4c5d6e7",
   "metadata": {},
   "source": [
    "**Answer Q3: `02-vector-search/lessons/09-onnx-embedder.md`**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c5d6e7f8",
   "metadata": {},
   "source": [
    "## Q4. Vector search with minsearch"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d6e7f8a9",
   "metadata": {},
   "outputs": [],
   "source": [
    "from minsearch import VectorSearch\n",
    "\n",
    "index_v = VectorSearch()\n",
    "index_v.fit(X, chunks)\n",
    "\n",
    "query_q4 = \"What metric do we use to evaluate a search engine?\"\n",
    "v_q4 = embedder.encode(query_q4)\n",
    "\n",
    "results_q4 = index_v.search(v_q4, num_results=5)\n",
    "\n",
    "print(\"Top 5 results:\")\n",
    "for i, r in enumerate(results_q4):\n",
    "    print(f\"  {i+1}. {r['filename']}\")\n",
    "\n",
    "print(f\"\\nFirst result: {results_q4[0]['filename']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e7f8a9b0",
   "metadata": {},
   "source": [
    "**Answer Q4: `04-evaluation/lessons/05-search-metrics.md`**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f8a9b0c1",
   "metadata": {},
   "source": [
    "## Q5. Text search vs vector search"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a9b0c1d2",
   "metadata": {},
   "outputs": [],
   "source": [
    "from minsearch import Index\n",
    "\n",
    "index_text = Index(text_fields=[\"content\"], keyword_fields=[])\n",
    "index_text.fit(chunks)\n",
    "\n",
    "query_q5 = \"How do I store vectors in PostgreSQL?\"\n",
    "v_q5 = embedder.encode(query_q5)\n",
    "\n",
    "# Vector search top 5\n",
    "results_vector = index_v.search(v_q5, num_results=5)\n",
    "files_vector = {r[\"filename\"] for r in results_vector}\n",
    "\n",
    "# Text search top 5\n",
    "results_text = index_text.search(query_q5, num_results=5)\n",
    "files_text = {r[\"filename\"] for r in results_text}\n",
    "\n",
    "print(\"Vector results:\", files_vector)\n",
    "print()\n",
    "print(\"Text results:\", files_text)\n",
    "print()\n",
    "print(\"In vector but NOT in text:\", files_vector - files_text)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b0c1d2e3",
   "metadata": {},
   "source": [
    "**Answer Q5: `02-vector-search/lessons/02-embeddings.md`**\n",
    "\n",
    "(`08-pgvector.md` contains the literal word \"PostgreSQL\" so it appears in text results. `02-embeddings.md` is semantically relevant but has no exact keyword match, so it only shows up in vector results.)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c1d2e3f4",
   "metadata": {},
   "source": [
    "## Q6. Hybrid search with RRF"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d2e3f4a5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def rrf(result_lists, k=60, num_results=5):\n",
    "    scores = {}\n",
    "    docs = {}\n",
    "\n",
    "    for results in result_lists:\n",
    "        for rank, doc in enumerate(results):\n",
    "            key = (doc[\"filename\"], doc[\"start\"])\n",
    "            scores[key] = scores.get(key, 0) + 1 / (k + rank)\n",
    "            docs[key] = doc\n",
    "\n",
    "    ranked = sorted(scores, key=scores.get, reverse=True)\n",
    "    return [docs[key] for key in ranked[:num_results]]\n",
    "\n",
    "\n",
    "query_q6 = \"How do I give the model access to tools?\"\n",
    "v_q6 = embedder.encode(query_q6)\n",
    "\n",
    "vector_results = index_v.search(v_q6, num_results=5)\n",
    "text_results = index_text.search(query_q6, num_results=5)\n",
    "\n",
    "print(\"Vector results:\")\n",
    "for i, r in enumerate(vector_results):\n",
    "    print(f\"  {i+1}. {r['filename']}\")\n",
    "\n",
    "print(\"\\nText results:\")\n",
    "for i, r in enumerate(text_results):\n",
    "    print(f\"  {i+1}. {r['filename']}\")\n",
    "\n",
    "results = rrf([vector_results, text_results])\n",
    "\n",
    "print(\"\\nRRF results:\")\n",
    "for i, r in enumerate(results):\n",
    "    print(f\"  {i+1}. {r['filename']}\")\n",
    "\n",
    "print(f\"\\nFirst result after RRF: {results[0]['filename']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e3f4a5b6",
   "metadata": {},
   "source": [
    "**Answer Q6: `01-agentic-rag/lessons/13-function-calling.md`**\n",
    "\n",
    "(It's not #1 in either search alone, but ranks high in both — so RRF rewards it.)"
   ]
